# --- 1. CORE PATHS & ENV ---
# Ensure basic system paths are first
export PATH="/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

# OS & Architecture Specific Setup
if [[ "$OSTYPE" == "darwin"* ]]; then
    # Homebrew Setup (Mac)
    if [[ $(uname -m) == "arm64" ]]; then
        eval "$(/opt/homebrew/bin/brew shellenv)"
    else
        eval "$(/usr/local/bin/brew shellenv)"
    fi
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    # Linux specific settings
    [ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
fi

# --- 2. TOOL PATHS (Safe checks) ---
# Go
[ -d "$HOME/go/bin" ] && export PATH="$HOME/go/bin:$PATH"

# Volta
if [ -d "$HOME/.volta/bin" ]; then
    export VOLTA_HOME="$HOME/.volta"
    export PATH="$VOLTA_HOME/bin:$PATH"
fi

# Pyenv
if [ -d "$HOME/.pyenv" ]; then
    export PYENV_ROOT="$HOME/.pyenv"
    export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init --path 2>/dev/null)"
    eval "$(pyenv init - 2>/dev/null)"
fi

# Windsurf / Codeium
[ -d "$HOME/.codeium/windsurf/bin" ] && export PATH="$HOME/.codeium/windsurf/bin:$PATH"

# --- 3. SHELL FEATURES ---
# History
HISTSIZE=10000
SAVEHIST=10000
HISTFILE=~/.zsh_history
setopt APPEND_HISTORY SHARE_HISTORY HIST_IGNORE_DUPS HIST_IGNORE_ALL_DUPS HIST_REDUCE_BLANKS

# Zsh Completion
fpath=($fpath /opt/homebrew/share/zsh/site-functions)
autoload -Uz compinit && compinit

# --- 4. ALIASES & FUNCTIONS ---
# Load modular aliases if they exist
[[ -f ~/.dotfiles/zsh/aliases ]] && source ~/.dotfiles/zsh/aliases

# NVM (Lazy Load)
export NVM_DIR="$HOME/.nvm"
nvm() {
  unset -f nvm node npm npx
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
  [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
  nvm "$@"
}
node() { nvm current > /dev/null || nvm use default; node "$@" }
npm() { nvm current > /dev/null || nvm use default; npm "$@" }
npx() { nvm current > /dev/null || nvm use default; npx "$@" }

# AWS Aliases
alias awssso='aws sso login --sso-session vivotek'
alias awskey='function _awskey() { eval `aws configure export-credentials --format env --profile $1` }; _awskey'
alias awswho='aws sts get-caller-identity; aws iam list-account-aliases'

# General Aliases
alias ll='ls -alF'
alias gs='git status'
alias ta='tmux attach -t'
alias tn='tmux new -s'
alias tl='tmux ls'

# --- 5. LOCAL CONFIG (SECRETS) ---
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local

# iTerm2 Integration
test -e "$HOME/.iterm2_shell_integration.zsh" && source "$HOME/.iterm2_shell_integration.zsh" || true
